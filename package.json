{
  "name": "wp-agentic-admin",
  "version": "0.9.1",
  "description": "A privacy-first AI Site Reliability Engineer running entirely in the browser via WebLLM and the WordPress Abilities API.",
  "scripts": {
    "build": "npm run build:extensions",
    "build:extensions": "wp-scripts build src/extensions/index.js --output-path=build-extensions",
    "test:abilities": "node tests/abilities/runner.js",
    "watch": "wp-scripts start src/extensions/index.js --output-path=build-extensions",
    "clean": "del-cli build-extensions wp-agentic-admin.zip",
    "dist": "npm run clean && npm run build && rm -f wp-agentic-admin.zip && zip -r wp-agentic-admin.zip -@ < .distpackage",
    "test": "wp-scripts test-unit-js --testMatch='**/__tests__/**/*.test.js'",
    "test:watch": "npm run test -- --watch",
    "lint:js": "wp-scripts lint-js src/",
    "lint:js:fix": "wp-scripts lint-js src/ --fix",
    "lint:css": "wp-scripts lint-style 'src/**/*.scss'",
    "lint:css:fix": "wp-scripts lint-style 'src/**/*.scss' --fix",
    "lint:php": "composer lint",
    "lint:php:fix": "composer lint:fix",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:php",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix && npm run lint:php:fix"
  },
  "devDependencies": {
    "@wordpress/scripts": "^31.0.0",
    "del-cli": "^5.1.0"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.80",
    "fastest-levenshtein": "^1.0.16"
  },
  "keywords": [
    "wordpress",
    "plugin",
    "ai",
    "webllm",
    "webgpu",
    "abilities-api"
  ],
  "author": "Pluginslab",
  "license": "GPL-2.0-or-later"
}
